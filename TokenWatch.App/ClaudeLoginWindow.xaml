<Window x:Class="TokenWatch.App.ClaudeLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Claude ログイン — TokenWatch"
        Width="520" Height="700"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI, Yu Gothic UI">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FFF3F3F3" Padding="10">
            <TextBlock TextWrapping="Wrap" Foreground="#444" FontSize="12"
                       Text="claude.ai にログインしてください。ログインが完了したらこのウィンドウは閉じて構いません（セッションは保存され、使用量を自動取得します）。"/>
        </Border>
        <wv2:WebView2 x:Name="Web"/>
    </DockPanel>
</Window>
