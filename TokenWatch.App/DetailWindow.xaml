<Window x:Class="TokenWatch.App.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TokenWatch"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Topmost="True" FontFamily="Segoe UI, Yu Gothic UI">
    <Window.Resources>
        <!-- Compact toggle switch (ServiceNow green when on) -->
        <Style x:Key="ToggleSwitch" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Track" Width="36" Height="20" CornerRadius="10" Background="#CFCFCF">
                                <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="White"
                                         HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            </Border>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#62D84E"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FFFAFAFA" CornerRadius="10" Padding="14"
            BorderBrush="#22000000" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
        </Border.Effect>
        <StackPanel Width="320">
            <DockPanel>
                <TextBlock Text="TokenWatch" FontWeight="Bold" FontSize="15" Foreground="#222"/>
                <TextBlock x:Name="LastUpdatedText" DockPanel.Dock="Right"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#999" FontSize="11"/>
            </DockPanel>

            <StackPanel x:Name="Cards" Margin="0,10,0,0"/>

            <DockPanel Margin="0,12,0,0">
                <Button x:Name="ExitButton" Content="終了" DockPanel.Dock="Right"
                        Width="60" Height="26"/>
                <Button x:Name="RefreshButton" Content="更新" DockPanel.Dock="Right"
                        Width="60" Height="26" Margin="0,0,8,0"/>
                <CheckBox x:Name="PinToggle" Style="{StaticResource ToggleSwitch}"
                          DockPanel.Dock="Left" Content="最前面に固定" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Margin="6,0,8,0"
                           Foreground="#999" FontSize="11"/>
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
