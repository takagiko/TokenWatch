<Window x:Class="TokenWatch.App.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TokenWatch"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Topmost="True" FontFamily="Segoe UI, Yu Gothic UI">
    <Border Background="#FFFAFAFA" CornerRadius="10" Padding="14"
            BorderBrush="#22000000" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
        </Border.Effect>
        <StackPanel Width="320">
            <DockPanel>
                <TextBlock Text="TokenWatch" FontWeight="Bold" FontSize="15" Foreground="#222"/>
                <TextBlock x:Name="LastUpdatedText" DockPanel.Dock="Right"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#999" FontSize="11"/>
            </DockPanel>

            <StackPanel x:Name="Cards" Margin="0,10,0,0"/>

            <DockPanel Margin="0,12,0,0">
                <Button x:Name="ExitButton" Content="終了" DockPanel.Dock="Right"
                        Width="60" Height="26"/>
                <Button x:Name="RefreshButton" Content="更新" DockPanel.Dock="Right"
                        Width="60" Height="26" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Foreground="#999" FontSize="11"/>
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
