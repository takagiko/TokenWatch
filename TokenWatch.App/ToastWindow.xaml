<Window x:Class="TokenWatch.App.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" SizeToContent="Height"
        Width="350" Topmost="True" ShowActivated="False"
        FontFamily="Segoe UI, Yu Gothic UI">
    <Border Background="#FFFFFFFF" CornerRadius="10" Margin="8" BorderBrush="#22000000" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.28" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Accent" Grid.Column="0" Background="#C62828"
                    CornerRadius="10,0,0,10"/>
            <StackPanel Grid.Column="1" Margin="12,10,10,12">
                <DockPanel>
                    <Button x:Name="CloseBtn" DockPanel.Dock="Right" Content="✕"
                            Width="20" Height="20" Padding="0" FontSize="11"
                            Background="Transparent" BorderThickness="0" Foreground="#999"
                            Cursor="Hand"/>
                    <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="13"
                               Foreground="#222" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock x:Name="BodyText" FontSize="12" Foreground="#444"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
